# RKT Station Agent Configuration
# Copy this file to agent.env and fill in your values

# Agent identity
RKT_MODE=agent
RKT_STATION_ID=station-001

# Hardware settings (set to false when real hardware is connected)
RKT_SCAN_MOCK_MODE=true
RKT_PRINTER_MOCK_MODE=true
RKT_PRINTER_NAME=Epson ColorWorks C6000
RKT_NFC_MOCK_MODE=true

# NFC AES keys (32-char hex strings — get from your admin)
RKT_NFC_MASTER_KEY=
RKT_NFC_SDM_FILE_READ_KEY=
RKT_NFC_SDM_META_READ_KEY=
RKT_NFC_VERIFY_BASE_URL=https://rktgradingstation.co.uk/verify
